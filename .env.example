# The Collected Edit (static storefront) does not require runtime secrets today.
# Do not commit real `.env` files.

# App identity
APP_NAME=The Collected Edit
APP_SLUG=collected-edit-premium

# App - Future Ready / Not Active Yet
PUBLIC_SITE_URL=

# Temporary auth mode (future-ready)
# Keep disabled for this public deployment unless explicit auth launch is approved later.
NEXT_PUBLIC_AUTH_MODE=disabled
AUTH_REQUIRED=false

# Supabase - Future Ready / Not Active Yet
# Set these only when moving from localStorage to active backend.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Supabase admin keys (server-side only)
SUPABASE_SERVICE_ROLE_KEY=

# Optional future integrations (server-side only)
OPENAI_API_KEY=
RESEND_API_KEY=
